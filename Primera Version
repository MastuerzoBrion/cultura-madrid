// ═══════════════════════════════════════════════════
//  CONSTANTES & ESTADO
// ═══════════════════════════════════════════════════
const MESES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
const DIAS_MES_ABREV = ['En','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

let mesActual = new Date().getMonth() + 1;
let anioActual = new Date().getFullYear();
let semanaActual = (() => {
  const d = new Date(); d.setHours(0,0,0,0);
  d.setDate(d.getDate() - ((d.getDay()+6)%7)); return d;
})();
let vistaActual = 'mes';
let soloGratis = false;
let soloCompradas = false;
let soloPosibles = false;
let soloEntradas = false;
let filtrosCat = new Set(['todos']);
let panelAbierto = true;
let eventoModal = null;

const notasEventos = {};
try { const sn=localStorage.getItem('madridCultura_notas'); if(sn) Object.assign(notasEventos,JSON.parse(sn)); } catch(e){}

const misEntradas = new Map();
try { const se=localStorage.getItem('madridCultura_entradas'); if(se){const o=JSON.parse(se);Object.entries(o).forEach(([k,v])=>misEntradas.set(Number(k),v));} } catch(e){}

function guardarEntradas() {
  try { const o={}; misEntradas.forEach((v,k)=>o[k]=v); localStorage.setItem('madridCultura_entradas',JSON.stringify(o)); } catch(e){}
}

// Panel toggle
function togglePanelEntradas() {
  panelAbierto = !panelAbierto;
  const body = document.getElementById('lista-mis-entradas');
  const arrow = document.getElementById('arrow-entradas');
  if (body) body.classList.toggle('cerrado', !panelAbierto);
  if (arrow) arrow.classList.toggle('girado', !panelAbierto);
}


// ═══════════════════════════════════════════════════
//  FILTROS
// ═══════════════════════════════════════════════════
function toggleFiltro(btn) {
  const cat = btn.dataset.cat;
  if (cat === 'todos') {
    filtrosCat = new Set(['todos']);
    document.querySelectorAll('.filtro-btn[data-cat]').forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
  } else {
    filtrosCat.delete('todos');
    document.querySelector('.filtro-btn[data-cat="todos"]').classList.remove('on');
    if (filtrosCat.has(cat)) { filtrosCat.delete(cat); btn.classList.remove('on'); }
    else { filtrosCat.add(cat); btn.classList.add('on'); }
    if (filtrosCat.size === 0) {
      filtrosCat.add('todos');
      document.querySelector('.filtro-btn[data-cat="todos"]').classList.add('on');
    }
  }
  renderVista();
}
function toggleSoloGratis(btn) {
  soloGratis = !soloGratis;
  btn.classList.toggle('gratis-on', soloGratis);
  renderVista();
}
function toggleSoloCompradas(btn) {
  soloCompradas = !soloCompradas; soloPosibles = false;
  btn.classList.toggle('on', soloCompradas);
  document.getElementById('btn-solo-posibles')?.classList.remove('on');
  renderVista();
}
function toggleSoloPosibles(btn) {
  soloPosibles = !soloPosibles; soloCompradas = false;
  btn.classList.toggle('on', soloPosibles);
  document.getElementById('btn-solo-compradas')?.classList.remove('on');
  renderVista();
}
function eventosFiltrados() {
  const busqueda = (document.getElementById('buscador-cal')?.value || '').toLowerCase().trim();
  return EVENTOS.filter(ev => {
    const catOk = filtrosCat.has('todos') || filtrosCat.has(ev.cat);
    const gratisOk = !soloGratis || ev.gratis;
    const compradaOk = !soloCompradas || misEntradas.get(ev.id) === 'comprada';
    const posibleOk = !soloPosibles || misEntradas.get(ev.id) === 'posible';
    const entradasOk = !soloEntradas || misEntradas.has(ev.id);
    const busOk = !busqueda || ev.nombre.toLowerCase().includes(busqueda) ||
                  ev.lugar.toLowerCase().includes(busqueda) ||
                  (ev.desc||'').toLowerCase().includes(busqueda);
    return catOk && gratisOk && compradaOk && posibleOk && entradasOk && busOk;
  });
}

// ═══════════════════════════════════════════════════
//  NAVEGACIÓN CALENDARIO
// ═══════════════════════════════════════════════════
function navAnterior() {
  if (vistaActual === 'semana') {
    semanaActual = new Date(semanaActual); semanaActual.setDate(semanaActual.getDate() - 7);
  } else {
    mesActual--; if (mesActual < 1) { mesActual = 12; anioActual--; }
  }
  renderVista();
}
function navSiguiente() {
  if (vistaActual === 'semana') {
    semanaActual = new Date(semanaActual); semanaActual.setDate(semanaActual.getDate() + 7);
  } else {
    mesActual++; if (mesActual > 12) { mesActual = 1; anioActual++; }
  }
  renderVista();
}
function irAHoy() {
  const hoy = new Date();
  mesActual = hoy.getMonth() + 1; anioActual = hoy.getFullYear();
  semanaActual = new Date(hoy); semanaActual.setDate(hoy.getDate() - ((hoy.getDay()+6)%7));
  renderVista();
}
function cambiarVista(v, btn) {
  vistaActual = v;
  document.querySelectorAll('.vista-tab').forEach(t => t.classList.remove('activo'));
  if (btn) btn.classList.add('activo');
  renderVista();
}

// ═══════════════════════════════════════════════════
//  RENDER VISTA — dispatcher
// ═══════════════════════════════════════════════════
function renderVista() {
  const vMes = document.getElementById('vista-mes');
  const vSem = document.getElementById('vista-semana');
  const vLis = document.getElementById('vista-lista-cont');
  if (!vMes) return; // calendar section not in DOM yet
  if (vistaActual === 'mes') {
    vMes.style.display = 'block'; vSem.style.display = 'none'; vLis.style.display = 'none';
    renderMes();
  } else if (vistaActual === 'semana') {
    vMes.style.display = 'none'; vSem.style.display = 'block'; vLis.style.display = 'none';
    renderSemana();
  } else {
    vMes.style.display = 'none'; vSem.style.display = 'none'; vLis.style.display = 'block';
    renderLista();
  }
}

// ═══════════════════════════════════════════════════
//  RENDER MES
// ═══════════════════════════════════════════════════
function renderMes() {
  const titulo = document.getElementById('cal-titulo-periodo');
  if (titulo) titulo.textContent = MESES[mesActual-1] + ' ' + anioActual;

  const eventos = eventosFiltrados();
  const hoy = new Date();
  const primerDia = new Date(anioActual, mesActual-1, 1).getDay();
  const diasEnMes = new Date(anioActual, mesActual, 0).getDate();
  const offset = (primerDia === 0) ? 6 : primerDia - 1;

  // Group by day
  const porDia = {};
  eventos.forEach(ev => {
    ev.fechas.forEach(f => {
      if (f.m === mesActual) {
        if (!porDia[f.d]) porDia[f.d] = [];
        porDia[f.d].push(ev);
      }
    });
  });

  const container = document.getElementById('vista-mes');
  container.innerHTML = `
    <div class="cal-grid cal-grid-header">
      <div class="cal-dow">Lun</div><div class="cal-dow">Mar</div><div class="cal-dow">Mié</div>
      <div class="cal-dow">Jue</div><div class="cal-dow">Vie</div>
      <div class="cal-dow cal-dow-finde">Sáb</div><div class="cal-dow cal-dow-finde">Dom</div>
    </div>
    <div class="cal-grid" id="cal-celdas" style="margin-top:4px"></div>`;

  const contenedor = document.getElementById('cal-celdas');

  for (let i = 0; i < offset; i++) {
    const v = document.createElement('div'); v.className = 'cal-day vacio';
    contenedor.appendChild(v);
  }

  for (let d = 1; d <= diasEnMes; d++) {
    const dow = (offset + d - 1) % 7; // 0=Lun … 6=Dom
    const esFinde = dow >= 5;
    const celda = document.createElement('div');
    celda.className = 'cal-day' + (esFinde ? ' finde' : '');
    const esHoy = d === hoy.getDate() && mesActual === hoy.getMonth()+1 && anioActual === hoy.getFullYear();
    const esPasado = (anioActual < hoy.getFullYear()) ||
      (anioActual === hoy.getFullYear() && mesActual < hoy.getMonth()+1) ||
      (!esHoy && anioActual === hoy.getFullYear() && mesActual === hoy.getMonth()+1 && d < hoy.getDate());
    if (esHoy) celda.classList.add('hoy');
    if (esPasado) celda.classList.add('pasado');

    const numDiv = document.createElement('div');
    numDiv.className = 'num-dia'; numDiv.textContent = d;
    celda.appendChild(numDiv);

    const evsDia = porDia[d] || [];
    const MAX = 3;
    evsDia.slice(0, MAX).forEach(ev => {
      const pill = document.createElement('div');
      const estado = misEntradas.get(ev.id);
      pill.className = 'cal-evento ' + ev.color;
      if (estado === 'comprada') pill.classList.add('ev-comprada');
      else if (estado === 'posible') pill.classList.add('ev-posible');
      if (ev.gratis) pill.classList.add('gratis-tag');
      pill.textContent = ev.nombre;
      pill.title = ev.nombre;
      pill.onclick = () => abrirModal(ev);
      celda.appendChild(pill);
    });
    if (evsDia.length > MAX) {
      const mas = document.createElement('div');
      mas.className = 'cal-mas';
      mas.textContent = '+' + (evsDia.length - MAX) + ' más';
      mas.onclick = () => abrirListaDia(d, evsDia);
      celda.appendChild(mas);
    }
    contenedor.appendChild(celda);
  }
}

// ═══════════════════════════════════════════════════
//  RENDER SEMANA
// ═══════════════════════════════════════════════════
function renderSemana() {
  const eventos = eventosFiltrados();
  const hoy = new Date(); hoy.setHours(0,0,0,0);

  // semanaActual is a Monday
  const lunes = new Date(semanaActual);
  const domingo = new Date(lunes); domingo.setDate(lunes.getDate() + 6);

  const titulo = document.getElementById('cal-titulo-periodo');
  if (titulo) {
    const fmtOpts = { day:'numeric', month:'short' };
    titulo.textContent = lunes.toLocaleDateString('es-ES', fmtOpts) + ' – ' + domingo.toLocaleDateString('es-ES', fmtOpts);
  }

  // Sync mesActual/anioActual for filters consistency
  mesActual = lunes.getMonth() + 1; anioActual = lunes.getFullYear();

  const dias = [];
  for (let i = 0; i < 7; i++) {
    const d = new Date(lunes); d.setDate(lunes.getDate() + i);
    dias.push(d);
  }

  const NOMBRES_DIA = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];

  // Group events by day (check if event has a date in this week)
  const porDia = dias.map(dia => {
    const m = dia.getMonth()+1, dNum = dia.getDate(), a = dia.getFullYear();
    return eventos.filter(ev =>
      ev.fechas.some(f => f.m === m && f.d === dNum && (f.a ? f.a === a : true))
    );
  });

  const container = document.getElementById('vista-semana');
  container.innerHTML = `
    <div class="semana-grid">
      ${dias.map((dia, i) => {
        const esHoy = dia.getTime() === hoy.getTime();
        const esPasado = dia < hoy;
        const esFinde = i >= 5;
        const evs = porDia[i];
        return `<div class="semana-col${esFinde?' finde':''}${esPasado?' pasado':''}">
          <div class="semana-header${esHoy?' semana-hoy':''}">
            <span class="semana-dia-nombre">${NOMBRES_DIA[i]}</span>
            <span class="semana-dia-num${esHoy?' num-hoy':''}">${dia.getDate()}</span>
          </div>
          <div class="semana-eventos">
            ${evs.length === 0 ? '<div class="semana-vacio">—</div>' :
              evs.map(ev => {
                const estado = misEntradas.get(ev.id);
                let cls = 'semana-evento ' + ev.color;
                if (estado === 'comprada') cls += ' ev-comprada';
                else if (estado === 'posible') cls += ' ev-posible';
                if (ev.gratis) cls += ' gratis-tag';
                return `<div class="${cls}" onclick="abrirModal(EVENTOS.find(e=>e.id===${ev.id}))" title="${ev.nombre}">
                  ${ev.gratis ? '🆓 ' : ''}${ev.nombre}
                </div>`;
              }).join('')
            }
          </div>
        </div>`;
      }).join('')}
    </div>`;
}

// ═══════════════════════════════════════════════════
//  RENDER LISTA
// ═══════════════════════════════════════════════════
function renderLista() {
  const titulo = document.getElementById('cal-titulo-periodo');
  if (titulo) titulo.textContent = 'Todos los eventos';

  const eventos = eventosFiltrados();
  const hoy = new Date();

  // Expand each event into (date, event) pairs and sort
  const pares = [];
  eventos.forEach(ev => {
    ev.fechas.forEach(f => {
      const fecha = new Date(f.a || new Date().getFullYear(), f.m-1, f.d);
      pares.push({ fecha, ev });
    });
  });
  pares.sort((a,b) => a.fecha - b.fecha);

  // Group by month
  const porMes = {};
  pares.forEach(({ fecha, ev }) => {
    const key = fecha.getFullYear() + '-' + (fecha.getMonth()+1);
    if (!porMes[key]) porMes[key] = { label: MESES[fecha.getMonth()] + ' ' + fecha.getFullYear(), items: [] };
    porMes[key].items.push({ fecha, ev });
  });

  const container = document.getElementById('vista-lista-cont');
  if (Object.keys(porMes).length === 0) {
    container.innerHTML = '<p style="text-align:center;color:var(--gris);padding:40px">No hay eventos con estos filtros</p>';
    return;
  }

  container.innerHTML = Object.values(porMes).map(({ label, items }) => `
    <div class="lista-mes-grupo">
      <h4 class="lista-mes-titulo">${label}</h4>
      ${items.map(({ fecha, ev }) => {
        const estado = misEntradas.get(ev.id);
        const esPasado = fecha < hoy;
        const badge = estado === 'comprada'
          ? '<span class="badge-comprada">✓ Comprada</span>'
          : estado === 'posible'
          ? '<span class="badge-posible">♥ Quiero ir</span>'
          : '';
        return `<div class="lista-evento-item${esPasado?' lista-pasado':''}${estado?' tiene-entrada':''}" onclick="abrirModal(EVENTOS.find(e=>e.id===${ev.id}))">
          <div class="lista-cat-dot ${ev.color}"></div>
          <div class="lista-fecha-col">
            <div class="lista-dia">${fecha.getDate()}</div>
            <div class="lista-mes-abrev">${DIAS_MES_ABREV[fecha.getMonth()]}</div>
          </div>
          <div class="lista-info">
            <div class="lista-nombre">${ev.nombre} ${badge}</div>
            <div class="lista-meta">${ev.lugar}</div>
          </div>
          <div class="lista-precio-col">
            <span class="tag-precio ${ev.gratis?'gratis':'pago'}">${ev.gratis?'Gratis':ev.precio}</span>
          </div>
        </div>`;
      }).join('')}
    </div>`).join('');
}


// ═══════════════════════════════════════════════════
//  MIS ENTRADAS
// ═══════════════════════════════════════════════════
function setEstadoEntrada(id, estado) {
  if (estado === null) {
    misEntradas.delete(id);
  } else {
    misEntradas.set(id, estado);
  }
  guardarEntradas();
  // Re-render modal with updated state
  const ev = EVENTOS.find(e => e.id === id);
  if (ev) abrirModal(ev);
  renderVista();
  renderMisEntradas();
}


function guardarNota(id) {
  const ta = document.getElementById('nota-' + id);
  if (ta) {
    notasEventos[id] = ta.value;
    try { localStorage.setItem('madridCultura_notas', JSON.stringify(notasEventos)); } catch(e) {}
    // Show saved confirmation
    const btn = ta.nextElementSibling;
    if (btn) { btn.textContent = '✓ Guardado'; setTimeout(() => btn.textContent = 'Guardar nota', 1500); }
  }
}

function renderMisEntradas() {
  const cont = document.getElementById('lista-mis-entradas');
  const sub = document.getElementById('sub-entradas');
  if (!cont) return;

  const compradas = [], posibles = [];
  misEntradas.forEach((estado, id) => {
    const ev = EVENTOS.find(e => e.id === id);
    if (!ev) return;
    if (estado === 'comprada') compradas.push(ev);
    else posibles.push(ev);
  });

  const total = compradas.length + posibles.length;
  if (sub) sub.textContent = total === 0
    ? 'Sin entradas guardadas · Haz clic en un evento para añadirlo'
    : `${compradas.length} comprada${compradas.length!==1?'s':''} · ${posibles.length} en lista`;

  if (total === 0) {
    cont.innerHTML = '<p class="entradas-vacias">Aún no has guardado ninguna entrada.<br><span style="opacity:0.6">Haz clic en cualquier evento del calendario y elige ✓ Comprada o ♥ Quiero ir</span></p>';
    return;
  }

  const renderGrupo = (evs, titulo, cls) => evs.length === 0 ? '' : `
    <div class="mei-grupo">
      <h5 class="mei-grupo-titulo ${cls}">${titulo} (${evs.length})</h5>
      ${evs.map(ev => {
        const nota = notasEventos[ev.id];
        const primeraFecha = ev.fechas.slice().sort((a,b)=>a.m-b.m||a.d-b.d)[0];
        return `<div class="mei-item" onclick="abrirModal(ev)">
          <div class="mei-dot ${ev.color}"></div>
          <div class="mei-info">
            <div class="mei-nombre">${ev.nombre}</div>
            <div class="mei-meta">${primeraFecha ? primeraFecha.d+' '+DIAS_MES_ABREV[primeraFecha.m-1] : ''} · ${ev.lugar.split('·')[0].trim()}</div>
            ${nota ? `<div class="mei-nota">📝 ${nota}</div>` : ''}
          </div>
          <button class="mei-del" onclick="event.stopPropagation();setEstadoEntrada(${ev.id},null)" title="Quitar">✕</button>
        </div>`;
      }).join('')}
    </div>`;

  cont.innerHTML = renderGrupo(compradas, '✓ Entradas compradas', 'titulo-comprada')
                 + renderGrupo(posibles, '♥ Quiero ir', 'titulo-posible');
}


function abrirModal(ev) {
  eventoModal = ev;
  const estado = misEntradas.get(ev.id); // 'comprada' | 'posible' | undefined
  const nota = notasEventos[ev.id] || '';
  const fechasStr = ev.fechas.slice(0, 6).map(f => `${f.d} ${DIAS_MES_ABREV[f.m-1]}`).join(' · ') + (ev.fechas.length > 6 ? ` · +${ev.fechas.length-6} más` : '');
  const tipoLabel = {opera:'Ópera & Lírica',musica:'Música Clásica',teatro:'Teatro / Danza',humor:'Humor & Monólogos',exposicion:'Exposición',museo:'Museo',libro:'Literatura'}[ev.cat] || ev.cat;
  const colMap = {opera:'#6a1a80',musica:'var(--azul)',teatro:'#a0520d',humor:'#8a6a00',exposicion:'var(--verde)',museo:'var(--rojo)',libro:'#7a5010'};

  document.getElementById('modal-contenido').innerHTML = `
    <div class="modal-tipo" style="color:${colMap[ev.cat]}">${tipoLabel}</div>
    <div class="modal-titulo">${ev.nombre}</div>
    <ul class="info-list">
      <li><span class="lbl">Lugar</span> ${ev.lugar}</li>
      <li><span class="lbl">Fechas</span> ${fechasStr}</li>
      <li><span class="lbl">Precio</span> <span class="tag-precio ${ev.gratis?'gratis':'pago'}">${ev.precio}</span></li>
    </ul>
    <p style="margin-top:14px;font-size:14px;color:var(--gris);line-height:1.6">${ev.desc}</p>

    <div style="margin-top:20px;display:flex;flex-wrap:wrap;gap:8px;align-items:center">
      ${ev.url ? `<a href="${ev.url}" target="_blank" rel="noopener" class="${ev.gratis ? 'btn-gratis-link' : 'btn-compra'}">
        ${ev.gratis ? '🆓 Web oficial' : '🎟 Comprar entradas'}
      </a>` : ''}
    </div>

    <div class="modal-entradas-btns">
      <p class="modal-entradas-label">¿Qué quieres hacer con este evento?</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn-estado-entrada btn-comprada ${estado==='comprada'?'activo':''}"
          onclick="setEstadoEntrada(${ev.id},'comprada')">
          ${estado==='comprada'?'✓ Entrada comprada':'✓ Marcar como comprada'}
        </button>
        <button class="btn-estado-entrada btn-posible ${estado==='posible'?'activo':''}"
          onclick="setEstadoEntrada(${ev.id},'posible')">
          ${estado==='posible'?'♥ En mi lista':'♥ Quiero ir'}
        </button>
        ${estado ? `<button class="btn-estado-entrada btn-quitar" onclick="setEstadoEntrada(${ev.id},null)">✕ Quitar</button>` : ''}
      </div>
    </div>

    <div class="modal-seccion modal-notas">
      <h5>📝 Notas (butaca, acompañante, reserva…)</h5>
      <textarea id="nota-${ev.id}" placeholder="Ej: Butaca F12, con Marta, confirmada…">${nota}</textarea>
      <button class="btn-guardar-nota" onclick="guardarNota(${ev.id})">Guardar nota</button>
    </div>
  `;
  document.getElementById('modal-overlay').classList.add('abierto');
}


function abrirListaDia(dia, evs) {
  document.getElementById('modal-contenido').innerHTML = `
    <div class="modal-tipo">Eventos del ${dia} ${MESES[mesActual-1]}</div>
    <div class="modal-titulo">Todos los eventos</div>
    ${evs.map(ev => `
      <div style="padding:12px 0;border-bottom:1px dotted var(--borde);cursor:pointer" onclick="abrirModal(EVENTOS.find(e=>e.id===${ev.id}))">
        <strong>${ev.nombre}</strong><br>
        <span style="font-size:12px;color:var(--gris)">${ev.lugar} · ${ev.precio}</span>
      </div>
    `).join('')}
  `;
  document.getElementById('modal-overlay').classList.add('abierto');
}

function cerrarModal(e) {
  if (e.target === document.getElementById('modal-overlay')) {
    document.getElementById('modal-overlay').classList.remove('abierto');
    renderMisEntradas();
  }
}
function cerrarModalBtn() {
  document.getElementById('modal-overlay').classList.remove('abierto');
  renderMisEntradas();
}

document.addEventListener('DOMContentLoaded', () => {
  // Init: show guide, hide calendar
  document.getElementById('seccion-calendario').style.display = 'none';
  document.getElementById('contenido-guia').style.display = 'block';
  // Init calendar state
  renderVista();
  renderMisEntradas();
  // Scroll to top button
  const btnTop = document.getElementById('btn-ir-arriba');
  window.addEventListener('scroll', () => {
    btnTop.classList.toggle('visible', window.scrollY > 300);
  });
  btnTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  // Escape closes modal
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      document.getElementById('modal-overlay').classList.remove('abierto');
      renderMisEntradas();
    }
  });
});
  btnTop.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      document.getElementById('modal-overlay').classList.remove('abierto');
      renderMisEntradas();
    }
  });
});
